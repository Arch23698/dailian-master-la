    "cors": "^2.8.6",
    "express": "^5.2.1",
    "next": "^14.2.25",
    "pg": "^8.13.1",
    "prisma": "7.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
